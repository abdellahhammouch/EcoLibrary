            "description": "Create a new reader account.\n\nMethod: POST  \nEndpoint: /api/register  \nAuth: Public\n\nRequest body:\n\n- name\n    \n- email\n    \n- password\n    \n- password_confirmation\n    \n\nResponse:\n\n- message\n    \n- user\n    \n- token"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "",
                  "if (data.token) {",
                  "    pm.environment.set(\"token\", data.token);",
                  "    console.log(\"Token enregistré :\", data.token);",
                  "} else {",
                  "    console.log(\"Aucun token trouvé dans la réponse\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
