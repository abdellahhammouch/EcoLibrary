                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Authenticate a user and return a Sanctum token.\n\nMethod: POST  \nEndpoint: /api/login  \nAuth: Public\n\nRequest body:\n\n- email\n    \n- password\n    \n\nResponse:\n\n- message\n    \n- user\n    \n- token"
